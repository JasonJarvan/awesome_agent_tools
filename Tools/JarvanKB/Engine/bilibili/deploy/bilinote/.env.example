# Copy to `.env` (docker compose auto-loads it), then: docker compose up -d
APP_PORT=3015              # browser-facing port; must match config/bilibili-engine.yaml base_url
TRANSCRIBER_TYPE=bcut      # B站必剪 free cloud ASR — no GPU, no Whisper model download, no API key
# LLM API keys are NOT set here. After first boot, add a provider in BiliNote's web UI
# (模型供应商); its key is stored in BiliNote's SQLite. Copy the provider_id into
# config/bilibili-engine.yaml.
